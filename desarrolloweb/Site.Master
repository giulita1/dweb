<%@ Master Language="C#" AutoEventWireup="true" CodeBehind="Site.master.cs" Inherits="desarrolloweb.SiteMaster" %>
<%@ Import Namespace="BE" %>

    <!DOCTYPE html>
<html lang="en">
<head runat="server">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="<%= ResolveUrl("~/Styles/site.css") %>" />
    <asp:ContentPlaceHolder ID="HeadContent" runat="server" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" />
    <script defer src="<%= ResolveUrl("~/ScriptsJS/site.js") %>"></script>
</head>
<body>
    <form runat="server">
    <header>

        <div class="logo-container">
            <p>HOTEL</p>
        </div> 
        <button type="button" id="btn-menu"><span class="material-symbols-outlined">menu</span>
    </button>
       
                <%
    string pagina = Request.Url.AbsolutePath.ToLower();
    bool logueado = Session["usuario"] != null;
    int rol = 0;
    if (logueado)
        rol = ((desarrolloweb.BE.Usuario)Session["usuario"]).IdRol;
    bool esAdmin  = rol == 1;
    bool esCliente = rol == 2;
%>

        <nav id="nav-menu">
    <ul>
        <li class="nav-items">
            <a href="<%= ResolveUrl("~/UI/Inicio.aspx") %>">Inicio</a>
        </li>

        <% if (!logueado && !pagina.Contains("login.aspx")) { %>
            <li class="nav-items">
                <a href="<%= ResolveUrl("~/UI/Login.aspx") %>">Iniciar sesión</a>
            </li>
        <% } %>

        <% if (!logueado && !pagina.Contains("registro.aspx")) { %>
            <li class="nav-items">
                <a href="<%= ResolveUrl("~/UI/Registro.aspx") %>">Registrarse</a>
            </li>
        <% } %>

        <% if (esAdmin) { %>
            <li class="nav-items nav-dropdown">
                <button type="button" class="btn-dropdown">
                    Administración
                    <span class="material-symbols-outlined">expand_more</span>
                </button>
                <ul class="dropdown-menu">
                    <li><a href="<%= ResolveUrl("~/UI/Bitacora.aspx") %>">
                        <span class="material-symbols-outlined">history</span>Bitácora
                    </a></li>
                    <li><a href="<%= ResolveUrl("~/UI/DigitoVerificador.aspx") %>">
                        <span class="material-symbols-outlined">verified</span>Dígito Verificador
                    </a></li>
                    <li><a href="<%= ResolveUrl("~/UI/PanelHabitaciones.aspx") %>">
                        <span class="material-symbols-outlined">bed</span>Panel de Habitaciones
                    </a></li>
                    <li><a href="<%= ResolveUrl("~/UI/PanelUsuarios.aspx") %>">
                        <span class="material-symbols-outlined">group</span>Panel de Usuarios
                    </a></li>
                </ul>
            </li>
        <% } %>

        <% if (logueado) { %>
            <li class="nav-items">
                <button type="button" id="btn-perfil">
                    <span class="material-symbols-outlined">account_circle</span>
                </button>
            </li>

            <% if (esCliente) { %>
                <li class="nav-items">
                    <button type="button" id="btn-carrito">
                        <span class="material-symbols-outlined">shopping_cart</span>
                    </button>
                </li>
            <% } %>
        <% } %>

    </ul>
</nav>
    </header>
    
    <main>
   
        <asp:ContentPlaceHolder ID="MainContent" runat="server" />
  
    </main>

   <footer class="footer">

    <div class="footer-contenido">

        <div class="footer-seccion">
            <h3>Contacto</h3>
            <p>hotelpatagonia2026@gmail.com</p>
            <p>+54 11 1234-5678</p>
        </div>

        <div class="footer-seccion">
            <h3>Ubicación</h3>
            <p>Av. Patagonia 1250</p>
            <p>Bariloche, Río Negro</p>
            <p>Argentina</p>
        </div>

    </div>

    <div class="footer-bottom">
        © 2026 Hotel Patagonia. Todos los derechos reservados.
    </div>

</footer>
        <% if (logueado) { %>
<div id="overlay-carrito"></div>
<div id="carrito">

    <div class="carrito-header">
        <h2>Tu carrito</h2>
        <button type="button" id="btn-cerrar-carrito">
            <span class="material-symbols-outlined">close</span>
        </button>
    </div>

    <div class="carrito-contenido" id="carrito-contenido">

        <div class="carrito-vacio" id="carrito-vacio">
            <span class="material-symbols-outlined">hotel</span>
            <p>Todavía no seleccionaste ninguna habitación.</p>
        </div>

        <div id="carrito-item" style="display:none">

            <div class="item-habitacion">
                <div class="item-img-wrapper">
                    <img id="carrito-img" src="" alt="Habitación">
                </div>
                <div class="item-info">
                    <span class="item-tipo" id="carrito-tipo"></span>
                    <h3 id="carrito-nombre"></h3>
                    <p class="item-fechas" id="carrito-fechas"></p>
                    <p class="item-noches" id="carrito-noches"></p>
                </div>
            </div>

            <div class="carrito-extra">
               <label class="extra-item">
                <span class="extra-info">
                    <span class="material-symbols-outlined">free_breakfast</span>
                    <span class="extra-info-texto">
                        <span class="extra-titulo">Desayuno incluido</span>
                        <small>Por persona, por noche</small>
                    </span>
                </span>
                <span class="extra-derecha">
                    <span id="precio-desayuno">+ $5.000</span>
                    <input type="checkbox" id="chk-desayuno">
                </span>
            </label>
            </div>

        </div>

    </div>

    <div class="carrito-footer" id="carrito-footer" style="display:none">
        <div class="total-desglose">
            <div class="total-fila">
                <span id="lbl-precio-hab"></span>
                <span id="val-precio-hab"></span>
            </div>
            <div class="total-fila" id="fila-desayuno" style="display:none">
                <span id="lbl-desayuno"></span>
                <span id="val-desayuno"></span>
            </div>
            <div class="total-fila total-final">
                <span>Total</span>
                <span id="val-total"></span>
            </div>
        </div>
        <button type="button" class="btn-confirmar" id="btn-confirmar">
            Confirmar reserva
        </button>
    </div>

</div>
<% } %>

        <% if (logueado) { %>
<div id="overlay-perfil"></div>
<div id="panel-perfil">

    <div class="perfil-header">
        <div class="perfil-avatar">
            <span class="material-symbols-outlined">account_circle</span>
        </div>
        <div class="perfil-info">
            <h2><%= ((desarrolloweb.BE.Usuario)Session["usuario"]).Nombre %> <%= ((desarrolloweb.BE.Usuario)Session["usuario"]).Apellido %></h2>
            <p><%= ((desarrolloweb.BE.Usuario)Session["usuario"]).Email %></p>
        </div>
        <button type="button" id="btn-cerrar-perfil">
            <span class="material-symbols-outlined">close</span>
        </button>
    </div>

    <div class="perfil-contenido">

        <% if (((desarrolloweb.BE.Usuario)Session["usuario"]).IdRol == 2) { %>
        <a href="<%= ResolveUrl("~/UI/MisReservas.aspx") %>" class="perfil-item">
            <span class="material-symbols-outlined">luggage</span>
            <div>
                <p>Mis Reservas</p>
                <small>Revisá y gestioná tus reservas</small>
            </div>
            <span class="material-symbols-outlined perfil-chevron">chevron_right</span>
        </a>
        <% } %>

        <% if (((desarrolloweb.BE.Usuario)Session["usuario"]).IdRol == 1) { %>
        <a href="<%= ResolveUrl("~/UI/Bitacora.aspx") %>" class="perfil-item">
            <span class="material-symbols-outlined">history</span>
            <div>
                <p>Bitácora</p>
                <small>Registro de actividad</small>
            </div>
            <span class="material-symbols-outlined perfil-chevron">chevron_right</span>
        </a>
        <a href="<%= ResolveUrl("~/UI/PanelHabitaciones.aspx") %>" class="perfil-item">
            <span class="material-symbols-outlined">bed</span>
            <div>
                <p>Panel de Habitaciones</p>
                <small>Administrá las habitaciones</small>
            </div>
            <span class="material-symbols-outlined perfil-chevron">chevron_right</span>
        </a>
        <a href="<%= ResolveUrl("~/UI/PanelUsuarios.aspx") %>" class="perfil-item">
            <span class="material-symbols-outlined">group</span>
            <div>
                <p>Panel de Usuarios</p>
                <small>Administrá los usuarios</small>
            </div>
            <span class="material-symbols-outlined perfil-chevron">chevron_right</span>
        </a>
        <% } %>

    </div>

    <div class="perfil-footer">
        <asp:LinkButton ID="btnCerrarSesion2" runat="server"
            OnClick="btnCerrarSesion_Click"
            CssClass="btn-cerrar-sesion">
            <span class="material-symbols-outlined">logout</span>
            Cerrar sesión
        </asp:LinkButton>
    </div>

</div>
<% } %>
    </form>
    </body>
    </html>

